{
  "expo": {
    "name": "SentinelX",
    "slug": "sentinelx-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sentinelx",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.sentinelx.mobile"
    },
    "android": {
      "package": "ai.sentinelx.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "permissions": [
        "RECEIVE_SMS",
        "READ_SMS",
        "INTERNET",
        "FOREGROUND_SERVICE",
        "POST_NOTIFICATIONS",
        "READ_PHONE_STATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "./modules/sentinel-native/plugin",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00E5FF"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
